# ==============================================================================
# IntelliSuggest API Gateway Environment Configuration
#
# Instructions:
# 1. Copy this file to .env in the same directory.
# 2. Fill in the values for your specific environment (development, staging, production).
# 3. DO NOT commit the .env file to version control.
# ==============================================================================

# --- Application Settings ---
# The environment the application is running in (e.g., development, production, test)
NODE_ENV=development

# The port the API Gateway server will listen on
PORT=8080

# --- Service Discovery ---
# URLs for the backend microservices that the gateway will proxy requests to.
# In a Docker environment, these should be the service names defined in docker-compose.yml.
RECOMMENDATION_ENGINE_URL=http://recommendation-engine:5000
# DATA_PROCESSOR_API_URL=http://data-processor:8081 # Example if data processor exposes an API

# --- Security & Authentication ---
# Secret key for signing and verifying JSON Web Tokens (JWTs) for dashboard users.
# Use a long, random, and complex string for production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-that-is-very-long-and-secure

# How long a JWT should be valid for (e.g., 1h, 7d, 30m)
JWT_EXPIRES_IN=8h

# A secret key for validating requests from trusted internal services or external clients.
# This is separate from user authentication (JWTs).
INTERNAL_API_KEY=a-secure-key-for-service-to-service-communication

# --- CORS (Cross-Origin Resource Sharing) ---
# The allowed origin for API requests. For production, this should be your frontend's domain.
# Use a comma-separated list for multiple origins.
# Example: https://dashboard.intellisuggest.com,https://www.intellisuggest.com
CORS_ORIGIN=http://localhost:3000

# --- Rate Limiting ---
# Enable or disable rate limiting (true/false)
RATE_LIMIT_ENABLED=true

# The maximum number of requests allowed from an IP address in the specified window.
RATE_LIMIT_MAX_REQUESTS=100

# The time window for rate limiting in minutes.
RATE_LIMIT_WINDOW_MINUTES=15

# --- Caching (e.g., Redis) ---
# The API Gateway might use a cache like Redis for rate limiting, session storage, or caching responses.
REDIS_HOST=redis
REDIS_PORT=6379
# Leave blank if your Redis instance does not require a password.
REDIS_PASSWORD=

# --- Logging ---
# The level of detail for application logs (e.g., error, warn, info, http, verbose, debug, silly)
LOG_LEVEL=info